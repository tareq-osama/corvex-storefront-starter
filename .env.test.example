# Copy to .env.test (git-ignored) for the live integration suite (`pnpm test`).
#
# Requirements:
# - The Corvex backend (the-corvex-cms) must be running and reachable at CORVEX_API_URL.
# - This starter's own dev server must be running and reachable at BFF_URL — the
#   integration tests call the BFF (this app's /api/bff/* routes) over HTTP, exactly
#   like a real browser would, so cookies/headers round-trip realistically.
# - NEXT_PUBLIC_WORKSPACE_ID must point at a real, seeded workspace (companies.client_portal_id).
# - Stripe keys must be TEST MODE keys (sk_test_/pk_test_) tied to the same Stripe
#   account configured on that workspace's payment_providers row.

# --- Backend + starter under test ---
CORVEX_API_URL=http://localhost:3000
BFF_URL=http://localhost:3001
NEXT_PUBLIC_WORKSPACE_ID=your-test-workspace-slug

# --- Test member (created on first run via /api/bff/auth/register if missing) ---
TEST_MEMBER_EMAIL=storefront-test@example.com
TEST_MEMBER_PASSWORD=Test1234!

# --- Stripe test mode ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...

# --- Seeded fixtures in the test workspace (handles/slugs) ---
# A paid, physical or digital product that requires Stripe checkout.
TEST_PAID_PRODUCT_HANDLE=
# A free/digital product that can be claimed instantly without payment.
TEST_FREE_DIGITAL_PRODUCT_HANDLE=
# A published CMS collection with at least one published item.
TEST_CMS_COLLECTION_SLUG=
TEST_CMS_ITEM_SLUG=
# A discount code valid for TEST_PAID_PRODUCT_HANDLE (optional — cart discount test skips if unset).
TEST_DISCOUNT_CODE=
