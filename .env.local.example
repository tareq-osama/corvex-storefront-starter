# Copy to .env.local for local development.

# Base URL of the Corvex headless backend (the-corvex-cms), server-to-server only.
CORVEX_API_URL=http://localhost:3000

# Public base URL of the Corvex backend, used client-side to load images
# through its /v/ proxy (R2 is not publicly accessible). Usually the same
# host as CORVEX_API_URL.
NEXT_PUBLIC_CORVEX_API_URL=http://localhost:3000

# Workspace slug (companies.client_portal_id) this storefront serves.
NEXT_PUBLIC_WORKSPACE_ID=your-workspace-slug

# Stripe publishable key (test mode recommended for development).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Display name shown in the storefront header/footer.
NEXT_PUBLIC_SITE_NAME=My Store
